{
  "name": "tree-sitter-m",
  "version": "0.1.1",
  "description": "Tree-sitter grammar for the M (MUMPS) programming language. Generated from m-standard's grammar-surface.json (union of AnnoStd, YottaDB, IRIS).",
  "main": "bindings/node",
  "types": "bindings/node",
  "license": "AGPL-3.0",
  "author": "Rafael Richards",
  "keywords": [
    "tree-sitter",
    "parser",
    "m",
    "mumps",
    "vista",
    "yottadb",
    "iris"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "scripts": {
    "build-grammar": "node tools/build-grammar.js",
    "build-coverage": "node tools/build-coverage-corpus.js",
    "generate": "tree-sitter generate",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip",
    "test": "tree-sitter test && node --test 'lib/**/*.test.js' && node tools/coverage-gate.js",
    "test:corpus": "tree-sitter test",
    "test:lib": "node --test 'lib/**/*.test.js'",
    "test:coverage": "node tools/coverage-gate.js",
    "test:binding": "node --test bindings/node/binding_test.js",
    "smoke": "node tools/smoke-corpus.js",
    "bench": "node tools/perf-bench.js",
    "regen": "node tools/build-grammar.js && node tools/build-coverage-corpus.js && tree-sitter generate && npm test"
  },
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "prebuildify": "^6.0.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.25.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "tree-sitter": [
    {
      "scope": "source.m",
      "file-types": [
        "m",
        "mac",
        "int"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "m-standard": {
    "schema_version": "1",
    "source": "../m-standard/integrated/grammar-surface.json"
  }
}
