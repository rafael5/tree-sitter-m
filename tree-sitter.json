{
  "grammars": [
    {
      "name": "m",
      "camelcase": "M",
      "scope": "source.m",
      "path": ".",
      "file-types": ["m", "mac", "int"],
      "injection-regex": "^m$"
    }
  ],
  "metadata": {
    "version": "0.1.1",
    "license": "AGPL-3.0",
    "description": "Tree-sitter grammar for the M (MUMPS) programming language. Generated from m-standard's grammar-surface.json (union of AnnoStd, YottaDB, IRIS).",
    "authors": [
      { "name": "Rafael Richards" }
    ],
    "links": {
      "repository": "https://github.com/m-dev-tools/tree-sitter-m"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
